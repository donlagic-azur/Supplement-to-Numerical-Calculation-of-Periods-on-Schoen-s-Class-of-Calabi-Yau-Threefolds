LLLrepPSLQ1 := proc(V,prec := 30,debug := 0)
    local M,T,n,i,j;
    n := numelems(V):
    M := convert(IdentityMatrix(n),list):
    M := Transpose(Matrix([seq([seq(M[i*n+j],j = 1 .. n)],i = 0 .. n-1),
        convert(10^prec*convert(V,Vector),list)]));
    print(M);
    M := Re(M)+1.000002325251289365235239852705270275272475765759527352*Im(M);
    print(M);
    M := LLL(M);
    print(M);
    # M ~ M;
    for i from 1 to n do
        T := M[i];
        Remove(T,n+1);
        print([T, ListTools:-DotProduct(convert(V,list),convert(T,list))]);
    end do:
    M := M[1];
    Remove(M,n+1);
    T := ListTools:-DotProduct(convert(V,list),convert(M,list));
    if abs(T)>10^(-20) and debug = 0 then
        M := `*`(0,convert(M,Vector)):
    end if:
    M
end proc:
