    rM[tt] := [seq(tM[1,tz],tz = 1 .. tn2)];
end do:
rM := Matrix(convert(rM,list));
# Vector, Vector
evalf(`*`~(rM . Vector(Eres2)-Vector(Eres1),rM . Vector(Eres2)+Vector(Eres1)),45);
round(Determinant(rM));
