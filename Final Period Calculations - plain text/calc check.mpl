compare := proc(Eres1,Eres2)
    local tn1,tn2,coeffnew,tt,tx,tz,tM,rM,digRe,digIm;
    coeffnew := 1.187241682451252893525893275023958089465165156489153163419811106891316033128919637:
    tn1 := numelems(Eres1):
    tn2 := numelems(Eres2):
    rM := Vector(tn1):
    digRe := 34;
    digIm := 30;
    for tt from 1 to tn1 do
        tM := Matrix([seq([seq(0,tz = 1 .. tn2), 1, 10^digRe*Re(Eres1[tt]), 10^digIm*Im(Eres1[tt])],tx = 1 .. 1),
            seq([seq(IdentityMatrix(tn2)[tx,tz],tz = 1 .. tn2), 0, 10^digRe*Re(Eres2[tx]),
            10^digIm*Im(Eres2[tx])],tx = 1 .. tn2)]):
        print(Eres1[tt]);
        tM := LLL(tM);
        if abs(tM[1,tn2+1])<>1 then
            print("??", evalf(tM,10));
        end if:
        rM[tt] := [seq(round(tM[1,tz])/round(tM[1,tn2+1]),tz = 1 .. tn2)];
    end do:
    rM := Matrix(convert(rM,list));
end proc:
